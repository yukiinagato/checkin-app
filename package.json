{
  "name": "hotel-app-root",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "install:all": "pnpm install",
    "backup:instance": "node scripts/backup-instance.mjs",
    "deploy": "node scripts/deploy.mjs",
    "notices": "node scripts/generate-third-party-notices.mjs",
    "dev": "concurrently \"pnpm --filter server dev\" \"pnpm --filter client dev\"",
    "start": "pnpm --filter server start",
    "build": "pnpm --filter client build",
    "test": "pnpm --filter server test && pnpm --filter client test"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "pnpm": {
    "overrides": {
      "ip-address": "^10.1.1",
      "path-to-regexp@<0.1.13": "0.1.13",
      "qs@>=6.7.0 <6.14.2": "^6.14.2",
      "brace-expansion@<1.1.13": "^1.1.14",
      "brace-expansion@>=2.0.0 <2.0.2": "^2.0.2",
      "picomatch@<2.3.2": "^2.3.2",
      "picomatch@>=4.0.0 <4.0.4": "^4.0.4",
      "minimatch@<3.1.4": "^3.1.4",
      "@tootallnate/once": "^3.0.1",
      "flatted": "^3.4.2",
      "esbuild": "^0.25.0",
      "rollup": "^4.59.0",
      "lodash": "^4.18.1"
    }
  }
}
