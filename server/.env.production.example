PORT=3001
HOST=0.0.0.0
DB_PATH=./data/hotel.db
UPLOAD_DIR=./uploads
ADMIN_API_TOKEN=replace-with-a-long-random-bootstrap-token
CORS_ORIGIN=https://checkin.example.com,https://admin.checkin.example.com
WEBAUTHN_RP_ID=admin.checkin.example.com
WEBAUTHN_RP_NAME=Checkin Admin
WEBAUTHN_ORIGIN=https://admin.checkin.example.com
TRUST_PROXY=loopback
JSON_BODY_LIMIT=10mb
# 非图片接口的 JSON 请求体上限（图片接口仍走 JSON_BODY_LIMIT）
SMALL_JSON_BODY_LIMIT=256kb
MAX_IMAGE_BYTES=10485760
MAX_GUESTS_PER_SUBMISSION=12
REQUEST_TIMEOUT_MS=30000
MAX_TEXT_FIELD_LENGTH=200
MAX_PASSPORT_NUMBER_LENGTH=32
# 同时运行的护照 OCR 子进程上限；超过会排队，超时返回 503
OCR_MAX_CONCURRENCY=2
OCR_QUEUE_TIMEOUT_MS=15000
# 日志级别（trace/debug/info/warn/error/fatal），生产建议 info
LOG_LEVEL=info
PADDLE_OCR_PYTHON=./.venv/bin/python
PADDLE_OCR_RUNNER=./tools/paddle_ocr_runner.py
PADDLEOCR_HOME=./.ocr-models
XDG_CACHE_HOME=./.cache
PADDLE_HOME=./.paddle
CHECKIN_OCR_HOME=./.cache/home
PIP_CACHE_DIR=./.cache/pip
PYTHONPYCACHEPREFIX=./.cache/pycache
